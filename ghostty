# Font
font-family = Hack Nerd Font
font-size = 12
font-thicken = true

theme = Tinacious Design Dark

# macOS
macos-titlebar-style = native
macos-option-as-alt = true

# window
window-show-tab-bar = always
window-new-tab-position = current

# Splits inherit cwd (replaces kitty's --cwd=current)
split-inherit-working-directory = true

# Keybindings — tabs
keybind = super+shift+a=previous_tab
keybind = super+shift+s=next_tab
keybind = super+shift+[=move_tab:-1
keybind = super+shift+]=move_tab:1

keybind = super+shift+i=prompt_tab_title

# Keybindings — new split
keybind = super+shift+enter=new_split:down
keybind = super+shift+space=new_split:right

# Keybindings — focus split
keybind = super+shift+p=goto_split:next
keybind = super+shift+left=goto_split:left
keybind = super+shift+right=goto_split:right
keybind = super+shift+up=goto_split:up
keybind = super+shift+down=goto_split:down

# Keybindings — resize split
keybind = super+shift+backslash=resize_split:left,10
keybind = super+shift+backspace=resize_split:right,10
